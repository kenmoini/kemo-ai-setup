# =============================================================================
# Component Toggles
# Copy this file to .env and modify as needed.
# Set to 'true' to enable, 'false' to disable.
# =============================================================================

# --- Core Tools (enabled by default) ---
ENABLE_GIT=true
ENABLE_BUILD_ESSENTIALS=true

# --- Node.js Ecosystem ---
ENABLE_NODEJS=true
ENABLE_PNPM=false
ENABLE_BUN=false

# --- AI CLI Tools (require Node.js - auto-enabled if needed) ---
ENABLE_CLAUDE_CODE=true
ENABLE_CODEX=false
ENABLE_GEMINI=false

# --- Programming Languages ---
ENABLE_PYTHON=true
ENABLE_GOLANG=false
ENABLE_RUST=false
ENABLE_PHP=false

# --- Java Ecosystem (Maven/Gradle imply OpenJDK) ---
ENABLE_OPENJDK=false
ENABLE_MAVEN=false
ENABLE_GRADLE=false
