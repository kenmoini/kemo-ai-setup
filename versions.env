# =============================================================================
# Version Pins - sourced by install.sh
# Modify these to control which versions get installed.
# =============================================================================

# Node.js major version (module stream for dnf, formula version for brew)
NODEJS_VERSION=22

# Go version (used for direct download on Debian; RHEL/macOS use repo defaults)
GOLANG_VERSION=1.24.2

# OpenJDK major version
OPENJDK_VERSION=25

# PHP module stream version
PHP_VERSION=8.3

# Maven module stream version (RHEL only; Debian/macOS use repo defaults)
MAVEN_VERSION=3.9

# Gradle version (downloaded from services.gradle.org)
GRADLE_VERSION=8.12

# Bun version ('latest' or specific semver like '1.1.0')
BUN_VERSION=latest

# Rust install method: 'rustup' (upstream installer) or 'repo' (system package)
RUST_INSTALL_METHOD=rustup

# Python version to install via pyenv (e.g. '3.14', '3.13.2', '3.12')
# pyenv resolves prefixes to the latest patch release.
PYTHON_VERSION=3.14
